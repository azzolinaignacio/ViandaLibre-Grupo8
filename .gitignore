# .gitignore for ViandaLibre Web

# Environment variables
.env

# Logs
*.log
logs/

# Database
*.db
*.sqlite
*.sqlite3

# PHP sessions
session/

# Vendor directories
vendor/

# IDE files
.vscode/
.idea/

# Recursos de Usuario
# No subir las fotos que Doña Rosa carga en su servidor local
public/assets/img/*
!public/assets/img/.gitkeep

# OS files
.DS_Store
Thumbs.db

# Temporary files
tmp/
temp/

# Cache
cache/